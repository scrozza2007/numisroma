# Database Configuration
MONGODB_URI=your_mongodb_uri

# JWT Configuration
# CRITICAL: Generate secure random secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER reuse secrets across JWT/refresh/CSRF
JWT_SECRET=your_jwt_secret_change_this_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_must_be_different_and_changed_in_production
CSRF_SECRET=your_csrf_secret_change_this_in_production_and_keep_unique
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
ROTATE_REFRESH_TOKENS=true
MAX_REFRESH_TOKENS_PER_USER=5
TOKEN_ISSUER=numisroma-api
TOKEN_AUDIENCE=numisroma-client

# Server Configuration
PORT=4000
NODE_ENV=development

# Frontend Configuration (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Logging Configuration (optional)
LOG_LEVEL=info
LOG_QUERIES=false

# Redis Configuration (optional, for caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Cache Configuration (optional, in seconds)
# CACHE_DEFAULT_TTL=300
# CACHE_COINS_TTL=600
# CACHE_COLLECTIONS_TTL=300
# CACHE_USERS_TTL=900
# CACHE_SEARCH_TTL=180
# CACHE_FILTERS_TTL=1800
# Sentry error tracking (optional — leave blank to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics endpoint protection (optional)
# If set, requests to /metrics from non-localhost must supply this key
# in the X-Metrics-Api-Key header.
# METRICS_API_KEY=change-me-to-a-random-secret

# AWS S3 image storage (optional — falls back to local disk when unset)
# AWS_S3_BUCKET=numisroma-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_CUSTOM_DOMAIN=cdn.numisroma.example.com
