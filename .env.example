# Docker Compose environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Required security secrets ---
# Each MUST be a unique ≥64-char random value. Do not reuse across variables.
JWT_SECRET=replace_with_a_unique_64_char_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_unique_64_char_secret
CSRF_SECRET=replace_with_a_third_unique_64_char_secret

# --- MongoDB credentials ---
# These are consumed both by the mongo container (to initialise the root user)
# and by the backend (to build its connection string). They must match.
MONGO_INITDB_ROOT_USERNAME=numisroma
MONGO_INITDB_ROOT_PASSWORD=replace_with_a_long_random_password

# --- Environment ---
NODE_ENV=production

# --- Domain (docker-compose.prod.yml) ---
# Your domain without protocol, e.g. numisroma.com
# Frontend will be served at https://$DOMAIN
# Backend will be served at https://api.$DOMAIN
DOMAIN=numisroma.example.com

# --- Frontend API URL (used by docker-compose.yml for local dev only) ---
# In production this is derived automatically from DOMAIN above.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Frontend origins (comma-separated for multiple) ---
FRONTEND_URL=http://localhost:3000

# --- Backend port ---
PORT=4000

# --- MongoDB backup destination (docker-compose.prod.yml) ---
BACKUP_DIR=./backups

# --- Redis (optional — falls back to in-memory when unset) ---
# REDIS_URL=redis://localhost:6379

# --- Image storage: Cloudflare R2 or AWS S3 (optional — falls back to local disk) ---
# AWS_S3_BUCKET=numisroma-uploads
# AWS_REGION=auto
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_CUSTOM_DOMAIN=pub-xxxx.r2.dev
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com  # R2 only, omit for real AWS S3

# --- Admin API key (optional — required to access /api/cache endpoints) ---
# Min 32 chars. Generate with the same command above.
# ADMIN_API_KEY=replace_with_a_32_char_secret

# --- Sentry error tracking (optional) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Prometheus metrics protection (optional) ---
# METRICS_API_KEY=replace_with_a_random_secret
