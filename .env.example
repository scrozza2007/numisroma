# Docker Compose environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Required security secrets ---
# Each MUST be a unique ≥64-char random value. Do not reuse across variables.
JWT_SECRET=replace_with_a_unique_64_char_secret
REFRESH_TOKEN_SECRET=replace_with_a_different_unique_64_char_secret
CSRF_SECRET=replace_with_a_third_unique_64_char_secret

# --- MongoDB credentials ---
# These are consumed both by the mongo container (to initialise the root user)
# and by the backend (to build its connection string). They must match.
MONGO_INITDB_ROOT_USERNAME=numisroma
MONGO_INITDB_ROOT_PASSWORD=replace_with_a_long_random_password

# --- Environment ---
NODE_ENV=production

# --- Frontend origins (comma-separated for multiple) ---
FRONTEND_URL=http://localhost:3000

# --- Backend port exposed by compose ---
PORT=4000

# --- Caddy TLS (docker-compose.prod.yml) ---
DOMAIN=numisroma.example.com

# --- MongoDB backup destination (docker-compose.prod.yml) ---
BACKUP_DIR=./backups
